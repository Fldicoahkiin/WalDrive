# Sui network the MCP server talks to.
SUI_NETWORK=testnet

# Sui Move package that holds the file_record + share_link modules.
CONTRACT_PACKAGE_ID=0x2fc345f205e241e8941cc5228ed6dd76f11e82484b6583c4070bc63eb914b5f6

# Walrus testnet endpoints. Aggregator serves blobs (GET), publisher stores them (PUT).
WALRUS_AGGREGATOR=https://aggregator.walrus-testnet.walrus.space
WALRUS_PUBLISHER=https://publisher.walrus-testnet.walrus.space

# Dedicated signing keypair as a `suiprivkey1...` bech32 string.
# Generate one with: sui keytool generate ed25519 --json (then export the bech32 key).
# Never commit the real value or print it in logs.
WALDRIVE_KEYPAIR=suiprivkey1...
