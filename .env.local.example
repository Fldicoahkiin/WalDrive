# Sui Move package that holds file_record + share_link modules.
NEXT_PUBLIC_CONTRACT_PACKAGE_ID=0x

# Walrus testnet endpoints. Aggregator serves blobs (GET), publisher stores them (PUT).
NEXT_PUBLIC_WALRUS_AGGREGATOR=https://aggregator.walrus-testnet.walrus.space
NEXT_PUBLIC_WALRUS_PUBLISHER=https://publisher.walrus-testnet.walrus.space

# Sui network the frontend talks to.
NEXT_PUBLIC_SUI_NETWORK=testnet
